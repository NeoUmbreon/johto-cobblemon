{
    "initializationAction": [
        "q.run_command('tag ' + q.player.username + ' add InDialogue');",
        "q.run_command('tag ' + q.player.username + ' add Dialogue6');",
        "q.run_command('execute as ' + q.player.username + ' run function johto:sound/playlocalsfx {sfx:\"call\"}');"
    ],
    "escapeAction": [              
        ],

    "names": [
        "Professor Elm"
    ],
    "speakers": {
        "elm": {
            "name": "Professor Elm",
            "face": {
                "type": "artificial",
                "modelType": "npc",
                "identifier": "cobblemon:professorelm",
                "isLeftSide": true
            }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "elm",
            "lines": [
                {
                    "type": "expression",
                    "expression": "'H-hello? ' + q.player.username + '?';"
                }
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page2');"
                    }
                ]
            }
        },
        {
            "id": "page2",
            "speaker": "elm",
            "lines": [
                "It's a disaster! Uh, um, it's just terrible!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page3');"
                    }
                ]
            }
        },
        {
            "id": "page3",
            "speaker": "elm",
            "lines": [
                "What should I do? It... Oh, no..."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Next",
                        "value": "next",
                        "action": "q.dialogue.set_page('page4');"
                    }
                ]
            }
        },
        {
            "id": "page4",
            "speaker": "elm",
            "lines": [
                "Please get back here right now!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.run_command('tag ' + q.player.username + ' add Dialogue6');",
                            "q.run_command('tag ' + q.player.username + ' remove InDialogue');",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:sound/playlocalsfx {sfx:\"hangup\"}');",
                            "q.dialogue.close();"
                        ]
                    }
                ]
            }
        }
    ]
}