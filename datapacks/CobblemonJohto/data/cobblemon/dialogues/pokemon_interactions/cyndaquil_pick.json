{
    "initializationAction": [
        "q.run_command('execute at ' + q.player.username + ' run function johto:sound/playcry {species:\"cyndaquil\",distance:24,volume:1.5}');"
    ],
    "escapeAction": [],
    "speakers": {
        "pokemon": {
            "name": "Cyndaquil",
            "face": {
                "type": "artificial",
                "modelType": "pokemon",
                "identifier": "cobblemon:cyndaquil",
                "isLeftSide": true
            }
        },
        "elm": {
          "name": "Professor Elm",
          "face": {
            "type": "artificial",
            "modelType": "npc",
            "identifier": "cobblemon:professorelm",
            "isLeftSide": true
          }
        }
    },
    "pages": [
        {
            "id": "greeting",
            "speaker": "pokemon",
            "lines": [
                "So, you like Cyndaquil, the Fire-type Pokémon?"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Yes",
                        "value": "yes",
                        "action": [
                            "q.dialogue.set_page('accept');"
                        ]
                    },
                    {
                        "text": "No",
                        "value": "no",
                        "action": [
                            "q.dialogue.set_page('decline');"
                        ]
                    }
                ]
            }
        },

        
        {
            "id": "accept",
            "speaker": "elm",
            "lines": [
                "I think that's a great Pokémon too!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": [
                            "q.dialogue.close();",
                            "q.run_command('execute as ' + q.player.username + ' run function johto:sound/playlocalsfx {sfx:\"caughtmon\"}');",
                            "q.run_command('execute as ' + q.player.username + ' run pokegive cyndaquil level=5');",
                            "q.run_command('execute as ' + q.player.username + ' run scoreboard players set @s StarterPick 2');",
                            "q.run_command('execute as ' + q.player.username + ' run opendialogue professorelm_dialogue4 @s');"
                        ]
                    }
                ]
            }
        },

        
        {
            "id": "decline",
            "speaker": "elm",
            "lines": [
                "Think it over carefully. Your partner is important."
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Close",
                        "value": "close",
                        "action": 
                            "q.dialogue.close();"
                    }
                ]
            }
        }
    ]
}