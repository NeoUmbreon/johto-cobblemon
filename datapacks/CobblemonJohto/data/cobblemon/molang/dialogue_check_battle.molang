q.player.in_battle == true ? return 0;
q.run_command('execute as ' + q.npc.uuid + ' if entity @s[tag=trainerBusy] run return run tellraw ' + q.player.username + ' {"text":"That trainer is busy!","italic":true,"color":"gray"}');
q.npc.Config.trainer_id != 'cherrygrove_silver' && q.npc.name != 'Silver' ? { 
    q.run_command('execute as ' + q.player.username + ' if entity @s[tag=defeated.' + q.npc.Config.trainer_id + '] run return run opendialogue ' + q.npc.Config.trainer_id + '_end_defeated ' + q.player.username);
} : {
    q.run_command('execute as ' + q.player.username + ' unless entity @s[tag=defeated.' + q.npc.Config.trainer_id + '] run return fail');
};
q.run_command('tag ' + q.npc.uuid + ' add trainerBusy');
q.run_command('opendialogue ' + q.npc.Config.trainer_id + '_interaction ' + q.player.username);