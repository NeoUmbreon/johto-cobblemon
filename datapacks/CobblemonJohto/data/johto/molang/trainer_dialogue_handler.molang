c.player.in_battle ? return 0;
c.player.has_tag('Whiteout') ? return 0;
c.npc.has_tag('trainerBusy') ? return q.run_command('tellraw ' + c.player.username + ' {"text":"That trainer is busy!","italic":true,"color":"gray"}');

c.player.has_tag('defeated.' + c.npc.Config.trainer_id) ? return c.npc.run_dialogue(c.player, c.npc.Config.trainer_id + '_end_defeated');

q.run_script('store_battle_data', c.player, c.npc);
c.npc.add_tag('trainerBusy');
c.player.add_tag('InDialogue');
c.npc.run_dialogue(c.player, c.npc.Config.trainer_id + '_interaction');